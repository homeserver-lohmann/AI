{
  "mcpServers": {
    "sequential-thinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },

    "web_browser": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ]
    },

    "nixos": {
      "command": "uvx",
      "args": ["mcp-nixos"]
    },

    "lean-lsp": {
       "command": "uvx",
       "args": ["lean-lsp-mcp"]
    }
  }
}
